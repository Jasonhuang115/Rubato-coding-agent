# ============================================================
# Rubato API Keys
# ============================================================
# Copy this file to .env (or .env.local) and fill in your keys.
# Place in either:
#   - your project root (project-specific)
#   - ~/.rubato/.env (global fallback)
#
# Shell environment variables override everything.
# ============================================================

# ---- Provider (default: deepseek) ----
# Supported: deepseek | openai | anthropic | groq | openrouter | ollama | together | fireworks
# CODING_AGENT_PROVIDER=deepseek
# CODING_AGENT_MODEL=deepseek-chat
# CODING_AGENT_BASE_URL=https://api.deepseek.com/v1

# ---- API Keys (provider-specific) ----
# You only need ONE of these, matching your chosen provider.

# DeepSeek (https://platform.deepseek.com/api_keys)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Anthropic / Claude (https://console.anthropic.com/settings/keys)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# OpenAI (https://platform.openai.com/api-keys)
# OPENAI_API_KEY=sk-your-openai-api-key

# Groq (https://console.groq.com/keys)
# GROQ_API_KEY=gsk_your-groq-api-key

# OpenRouter (https://openrouter.ai/keys)
# OPENROUTER_API_KEY=sk-or-your-openrouter-key

# ---- Generic key (tried after provider-specific keys) ----
# CODING_AGENT_API_KEY=sk-your-api-key
